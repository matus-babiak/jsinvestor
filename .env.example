# Ecomail Integration (newsletter / lead z dotazníka)
ECOMAIL_API_KEY=your_key_here
ECOMAIL_LIST_ID=your_list_id

# Internal webhook — volá sa len na serveri (NIKDY nepoužívaj NEXT_PUBLIC_*)
WEBHOOK_URL=https://example.com/your-webhook

# Rate limiting (Upstash Redis) — voliteľné; bez toho je limit vypnutý
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
